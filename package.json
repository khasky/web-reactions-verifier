{
  "name": "web-reactions-verifier",
  "version": "1.0.0",
  "type": "module",
  "description": "Standalone CLI verifier for Web Reactions public counts and signed checkpoints",
  "license": "GPL-3.0-or-later",
  "author": "khasky (https://github.com/khasky)",
  "homepage": "https://github.com/khasky/web-reactions-verifier#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khasky/web-reactions-verifier.git"
  },
  "bugs": {
    "url": "https://github.com/khasky/web-reactions-verifier/issues"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/khasky"
    },
    {
      "type": "patreon",
      "url": "https://www.patreon.com/khasky"
    },
    {
      "type": "ko-fi",
      "url": "https://ko-fi.com/khasky"
    }
  ],
  "keywords": [
    "web-reactions",
    "transparency-log",
    "verifier",
    "merkle",
    "ed25519",
    "opentimestamps"
  ],
  "bin": {
    "web-reactions-verify": "src/verify.mjs"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "verify": "node src/verify.mjs",
    "selftest": "node src/revoke.selftest.mjs && node src/ots.selftest.mjs && node src/archive.selftest.mjs"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.13.0",
  "dependencies": {
    "@noble/ed25519": "^2.1.0"
  }
}
